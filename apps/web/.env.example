# 独立站环境变量示例
# 复制为 .env.local 并填入真实值

# ---------------------------------------------------------------------------
# 数据库 (Neon)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ---------------------------------------------------------------------------
# Stripe (香港公司 - 港区)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# 测试环境用 sk_test_ / pk_test_

# ---------------------------------------------------------------------------
# Resend (邮件)
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="hello@[域名]"
SUPPORT_EMAIL="support@[域名]"

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET="生成 32+ 位随机字符串"
BETTER_AUTH_URL="http://localhost:37000"

# ---------------------------------------------------------------------------
# 站点
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:37000"
NEXT_PUBLIC_BRAND_NAME="Nara Charm"

# ---------------------------------------------------------------------------
# 公司法定信息 (写进条款页,法律要求必须真实)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_COMPANY_NAME="Nara Charm Limited"          # 公司英文名
NEXT_PUBLIC_COMPANY_ADDRESS="Hong Kong"                  # 公司注册地址(英文)
NEXT_PUBLIC_COMPANY_REGISTRATION=""                      # 公司注册号(BR/CI,可选)
NEXT_PUBLIC_CONTACT_EMAIL="hello@naracharm.com"          # 联系邮箱
NEXT_PUBLIC_SUPPORT_EMAIL="support@naracharm.com"        # 客服邮箱
NEXT_PUBLIC_PRIVACY_EMAIL="privacy@naracharm.com"        # 隐私事务邮箱(GDPR)
NEXT_PUBLIC_RETURN_ADDRESS="Hong Kong"                   # 退货寄回地址

# ---------------------------------------------------------------------------
# 社交媒体 (footer 链接,留空则不显示)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_INSTAGRAM="naracharm"
NEXT_PUBLIC_TIKTOK="naracharm"
NEXT_PUBLIC_YOUTUBE="naracharm"
NEXT_PUBLIC_PINTEREST=""

# ---------------------------------------------------------------------------
# Plausible (分析)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""  # 上线后填域名
