# 独立站环境变量示例
# 复制为 .env.local 并填入真实值

# ---------------------------------------------------------------------------
# 数据库 (Neon)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ---------------------------------------------------------------------------
# Stripe (香港公司 - 港区)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# 测试环境用 sk_test_ / pk_test_

# ---------------------------------------------------------------------------
# Resend (邮件)
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="hello@[域名]"
SUPPORT_EMAIL="support@[域名]"

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET="生成 32+ 位随机字符串"
BETTER_AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# 站点
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BRAND_NAME="Silk & Steppe"  # 品牌名确认后改

# ---------------------------------------------------------------------------
# Plausible (分析)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""  # 上线后填域名
