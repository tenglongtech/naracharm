{
  "name": "handmade-jewelry-ecommerce",
  "version": "0.1.0",
  "private": true,
  "description": "手工民族融合首饰跨境电商独立站 + 内容矩阵",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
